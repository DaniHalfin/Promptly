    "node-fetch": "^3.3.2",
    "tiktoken": "^1.0.10"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
